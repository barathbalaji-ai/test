# Carta environment variables
# Copy to .env.local for local dev. On Vercel, set these in Project → Settings →
# Environment Variables (the Postgres integration injects POSTGRES_URL for you).

# --- Shared database (server-side, used by /api functions) ---
# Provided automatically when you add Vercel Postgres / Neon to the project.
# For local `vercel dev`, run `vercel env pull .env.local` to fetch it.
POSTGRES_URL=

# --- Future: Google Sign-In (client-side, see CARTA_BLUEPRINT §12) ---
# Public OAuth Web Client ID. Safe to expose (no client secret in an SPA).
VITE_GOOGLE_CLIENT_ID=
